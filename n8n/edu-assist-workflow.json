    {
      "parameters": {
        "jsCode": "return items.map((item) => {\n  const msg = item.json.message ?? item.json.edited_message ?? {};\n  const text = (msg.text ?? '').trim();\n  return {\n    json: {\n      raw: item.json,\n      chatId: msg.chat?.id ?? '',\n      userId: msg.from?.id ?? '',\n      userName: msg.from?.first_name ?? '',\n      userMessage: text,\n      normalizedMessage: text.toLowerCase(),\n      timestamp: new Date().toISOString()\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -960,
        120
      ],
      "id": "2d4c9f71-cf66-4b35-9b5c-4e6f3fa7a101",
      "name": "Prepare Input"
    },
    {
      "parameters": {
        "jsCode": "return items.map((item) => {\n  const text = item.json.normalizedMessage || '';\n  const hasAny = (...terms) => terms.some((term) => text.includes(term));\n\n  let intent = 'ai';\n  if (!text) intent = 'empty';\n  else if (hasAny('/start', 'ابدأ', 'ابدا', 'السلام', 'اهلا', 'مرحبا', 'hello', 'hi')) intent = 'welcome';\n  else if (hasAny('من انتم', 'ما هو الفريق', 'مين انتم', 'عرفني بالفريق', 'نبذة', 'نبذه', 'ايه هو الفريق')) intent = 'faq_about';\n  else if (hasAny('تواصل', 'اتواصل', 'لينك', 'رابط', 'contact', 'الموقع', 'website')) intent = 'faq_contact';\n  else if (hasAny('tech day', 'تك داي', 'techday', 'الفعالية', 'الفعاليات')) intent = 'faq_techday';\n\n  return {\n    json: {\n      ...item.json,\n      intent\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -740,
        120
      ],
      "id": "35a73238-6c03-4cae-8814-f8f45fb5ef21",
      "name": "Detect Intent"
    },
