      "id": "e792cb46-4d2d-4d6b-bc46-1bb876d2745b",
      "name": "Fetch Knowledge Base"
    },
    {
      "parameters": {
        "jsCode": "const original = $items('Detect Intent', 0, 0)[0].json;\nconst knowledge = items[0].json;\nconst list = Array.isArray(knowledge) ? knowledge : (knowledge.data || knowledge.items || []);\nconst text = (original.userMessage || '').toLowerCase();\nconst words = text.split(/\\s+/).filter((word) => word && word.length > 1);\n\nconst scored = list.map((entry) => {\n  const haystack = [entry.title, entry.content, ...(entry.keywords || [])].join(' ').toLowerCase();\n  let score = 0;\n  for (const word of words) {\n    if (haystack.includes(word)) score += 3;\n  }\n  for (const keyword of entry.keywords || []) {\n    if (text.includes(String(keyword).toLowerCase())) score += 5;\n  }\n  if ((entry.category || '').toLowerCase() === 'decisions' && text.includes('قرار')) score += 2;\n  return { entry, score };\n}).filter((row) => row.score > 0).sort((a, b) => b.score - a.score).slice(0, 4);\n\nconst knowledgeContext = scored.length\n  ? scored.map(({ entry }) => `- ${entry.title}: ${entry.content}`).join('\\n')\n  : 'لا توجد مقاطع معرفة مطابقة بشكل مباشر. اعتمد فقط على المعلومات الأساسية المتاحة، وإذا لم تتوفر معلومة مؤكدة فاذكر ذلك بوضوح.';\n\nreturn [{\n  json: {\n    ...original,\n    source: 'ai',\n    matchedKnowledge: scored.map(({ entry }) => entry.id).join(', '),\n    knowledgeContext\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -20,
        460
      ],
      "id": "98be4cd7-9179-4480-a862-1d6cd3b18ae8",
